<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="sec_impulse" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Using Impulse</title>

  <activity xml:id="class_ball-ground">
    <title>The Ball and the Ground</title>
	<introduction>
  <p></p>
      <p>
        You drop a <m>0.05 \mathrm{~kg}</m> tennis ball from rest and it takes <m>0.5 \mathrm{~s}</m> to hit the ground.
	  </p>
	</introduction>
	  <task>
		<statement>
	  <p>  
		Use the Impulse-Momentum theorem to find the velocity of the ball just before impact with the ground.
      </p>
	</statement>
	</task>
	<task>
		<statement>
			<p>
				The tennis ball rebounds from the ground with the same speed as impact.  The collision takes <m>0.01 \mathrm{~s}</m>.  
				Find the average net force on the tennis ball.
			</p>
		</statement>
	</task>
  </activity>

  <activity>
	<title>The Pitcher</title>
	<introduction>
		<p>
			
		</p>
		<p>
			A baseball pitcher throws a baseball toward home plate.  The mass of the baseball is about <m>145 \mathrm{~g}</m>.  It takes approximately <m>0.2 \mathrm{~s}</m> for the pitcher to speed up the ball.
		</p>
	</introduction>
	<task>
		<statement>
			<p>
				Estimate the speed of the ball (in m/s) as it leaves the pitcher's hand.
			</p>
		</statement>
	</task>
	<task>
		<statement>
			<p>
				Sketch a free-body diagram for the pitcher and the baseball.
			</p>
		</statement>
	</task>
	<task>
		<statement>
			<p>
				Is momentum conserved for the baseball?  For the pitcher?  For the system of both the baseball and the pitcher?
			</p>
		</statement>
	</task>
	<task>
		<statement>
			<p>
				Estimate the magnitude of the force the pitcher acts on the ball.
			</p>
		</statement>
	</task>
	<task>
		<statement>
			<p>
				Estimate the magnitude of any other forces acting on the pitcher.
			</p>
		</statement>
	</task>
	
  </activity>

	
</section>








